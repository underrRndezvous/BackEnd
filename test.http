    {
      "id": 1,
      "placeType": "RESTAURANT",
      "typeDetail": null,
      "atmosphere": null
    },
    {
      "id": 2,
      "placeType": "CAFE",
      "typeDetail": null,
      "atmosphere": "SOCIABLE"
    }
  ],
  "startPoint": [
    {
      "first": "서울특별시",
      "second": "마포구",
      "third": "서교동"
    },
    {
      "first": "서울특별시",
      "second": "마포구",
      "third": "합정동"
    }
  ]
}

