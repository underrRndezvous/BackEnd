### 1. 기본 케이스 - 금요일 저녁 모임 (강남)
POST https://swp.hoydev.com/meet
Content-Type: application/json

{
  "groupName": "친구모임",
  "meetTime": ["EVENING"],
  "meetDays": "FRIDAY",
  "place": [
    {
      "id": 1,
      "placeType": "RESTAURANT",
      "typeDetail": null,
      "atmosphere": null
    },
    {
      "id": 2,
      "placeType": "CAFE",
      "typeDetail": null,
      "atmosphere": "PRODUCTIVE"
    }
  ],
  "startPoint": [
    {
      "first": "서울특별시",
      "second": "강남구",
      "third": "역삼1동"
    }
  ]
}

