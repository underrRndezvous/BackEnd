### Host Configuration
### 사용할 호스트를 선택하세요 (한 줄만 주석 해제)

# Production Server
# @host = https://swp.hoydev.com

# Local Development Server  
@host = http://localhost:8080

### 1. 기본 케이스 - 금요일 저녁 모임 (강남)
POST {{host}}/meet
Content-Type: application/json

{
  "groupName": "친구모임",
  "meetTime": ["EVENING"],
  "meetDays": "FRIDAY",
  "place": [
    {
      "id": 1,
      "placeType": "RESTAURANT",
      "typeDetail": null,
      "atmosphere": null
    },
    {
      "id": 2,
      "placeType": "CAFE",
      "typeDetail": null,
      "atmosphere": "PRODUCTIVE"
    }
  ],
  "startPoint": [
    {
      "first": "서울특별시",
      "second": "강남구",
      "third": "역삼1동"
    }
  ]
}

### 2. 점심시간 모임 - 홍대 (다중 출발지)
POST {{host}}/meet
Content-Type: application/json

{
  "groupName": "회사동료모임",
  "meetTime": ["LUNCH"],
  "meetDays": "TUESDAY",
